# Server
PORT=8086
NODE_ENV=development

# Database (Catalog DB - Read Only)
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5432
CATALOG_DB_NAME=cataloglisting
CATALOG_DB_USER=catalog_node_reader
